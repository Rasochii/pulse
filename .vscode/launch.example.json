{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pulse (sem Supabase)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart"
    },
    {
      "name": "Pulse + Supabase",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "toolArgs": [
        "--dart-define=SUPABASE_URL=https://SEU_PROJETO.supabase.co",
        "--dart-define=SUPABASE_ANON_KEY=SUA_CHAVE_ANON_OU_PUBLISHABLE"
      ]
    },
    {
      "name": "Pulse (profile)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "flutterMode": "profile"
    },
    {
      "name": "Pulse (release)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "flutterMode": "release"
    }
  ]
}
